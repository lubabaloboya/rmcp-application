# Common configuration files to ignore
docker-compose.yml
docker-compose.*.yml
docker/.env
docker/php/entrypoint.sh
docker/php/opcache.ini
docker/nginx/conf.d/default.conf
web/angular.json
web/package-lock.json
web/package.json
api/.env
api/.env.*
api/phpunit.xml
api/composer.lock
api/composer.json
# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Environment files
.env
.env.*
!.env.docker.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker and runtime artifacts
*.pid
# Ignore docker-compose.yml
/docker-compose.yml

# PHP / Laravel
api/vendor/
api/storage/*.key
api/storage/logs/
api/storage/framework/cache/
api/storage/framework/sessions/
api/storage/framework/testing/
api/storage/framework/views/
api/bootstrap/cache/*.php

# Node / Angular
web/node_modules/
web/dist/
web/.angular/

# Ignore Laravel environment file
/api/.env

# Misc
*.tmp
*.swp
